{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.py": {
      "runtime": "python3.12",
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/upload", "destination": "/api/index.py" },
    { "source": "/split", "destination": "/api/index.py" },
    { "source": "/save", "destination": "/api/index.py" },
    { "source": "/pdf/(.*)", "destination": "/api/index.py" },
    { "source": "/", "destination": "/api/index.py" }
  ]
}
