{
  "model": "claude-sonnet-4-6",
  "env": {
    "MAX_THINKING_TOKENS": "10000"
  },
  "hooks": {
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "git add . && git commit -m 'Auto-save' && git push origin sprint/session-7 || true",
            "async": true,
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "git pull origin sprint/session-7 || true",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
