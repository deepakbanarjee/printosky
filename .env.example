META_SYSTEM_USER_TOKEN=your_long_lived_system_user_token
META_PHONE_NUMBER_ID=1022031308558582
# WhatsApp number that receives staff alerts (with country code, no +)
STORE_WHATSAPP_PHONE=919495706405

RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=YourWebhookSecretHere
STORE_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxx
# Get from Supabase dashboard: Settings → API → service_role key
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxx
# Supabase Auth service account (create once in Authentication → Users)
SUPABASE_AUTH_EMAIL=admin@printosky.internal
SUPABASE_AUTH_PASSWORD=YourStrongPasswordHere

# Auth hashes — set these in Netlify dashboard too (Site > Environment variables)
# Generate with: node -e "const c=require('crypto'); c.pbkdf2('yourpass', Buffer.from('yoursalt','hex'), 600000, 32, 'sha256', (e,k)=>console.log(k.toString('hex')))"
ADMIN_PBKDF2_SALT=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADMIN_PBKDF2_HASH=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPERADMIN_SHA256_HASH=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STORE_SHA256_HASH=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MIS_SHA256_HASH=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Epson WF-C21000 web admin credentials (LAN-only printer — used by printer_poller.py + epson_jobs_fetcher.py)
# Default username is "Oxygen"; update EPSON_PASS here if you change it via the Epson web UI
EPSON_USER=Oxygen
EPSON_PASS=your_epson_web_admin_password
